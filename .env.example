# EdgeTunnel Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration (Neon Postgres)
# ============================================
DATABASE_URL="postgresql://username:password@host/neondb?sslmode=require&channel_binding=require"

# ============================================
# Stack Auth Configuration
# ============================================
NEXT_PUBLIC_STACK_PROJECT_ID="your-project-id"
STACK_SECRET_SERVER_KEY="ssk_your_secret_key_here"

# ============================================
# Cloudflare Worker Configuration
# ============================================
# Worker signing secret for request verification
REQUEST_SIGNING_SECRET="your-request-signing-secret"

# Shared secret for controller communication
CONTROLLER_SHARED_SECRET="your-controller-shared-secret"

# Internal token for worker-to-controller auth
CONTROLLER_INTERNAL_TOKEN="your-internal-token"

# ============================================
# Cloudflare Services (Optional - for production)
# ============================================
# KV Namespace for rate limiting (if using KV)
# RATE_LIMIT_KV_ID="your-kv-namespace-id"

# D1 Database for usage logs (if using D1)
# USAGE_DB_ID="your-d1-database-id"

# ============================================
# Worker URLs
# ============================================
# The deployed worker URL
PROXY_CONTROLLER_URL="https://controller.edgetunnel.internal"

# Stack Auth introspection endpoint
STACKAUTH_VALIDATE_URL="https://api.stack-auth.com/v1/introspect"

# ============================================
# Proxy Configuration
# ============================================
# JSON array of proxy nodes (for development/testing)
PROXY_NODES_JSON="[{\"id\":\"node-us-east\",\"region\":\"us-east\",\"endpoint\":\"http://localhost:8080\",\"dedicatedOnly\":false}]"

# ============================================
# Backend Server
# ============================================
PORT=8080
